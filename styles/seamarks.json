    {
      "id": "signal_station_*[symbol]",
      "type": "symbol",
      "source": "seamarks",
      "source-layer": "seamarks",
      "minzoom": 11,
      "filter": [
        "any",
        ["==", "seamark:type", "signal_station_traffic"],
        [
          "all",
          ["==", "seamark:type", "signal_station_warning"],
          ["!=", "seamark:signal_station_warning:category", "tide_gauge"],
          ["!=", "seamark:signal_station_warning:category", "depth"],
          ["!=", "seamark:signal_station_warning:category", "water_level_gauge"]
        ]
      ],
      "layout": {
        "icon-allow-overlap": true,
        "icon-ignore-placement": true,
        "text-optional": true,
        "text-allow-overlap": false,
        "text-field": [
          "format",
          [
            "case",
            [
              "any",
              ["has", "seamark:signal_station_traffic:category"],
              ["has", "seamark:signal_station_warning:category"]
            ],
            [
              "concat",
              "SS(",
              [
                "match",
                ["get", "seamark:signal_station_traffic:category"],
                "bridge_passage",
                "Bridge",
                "port_entry_departure",
                "Port",
                [
                  "coalesce",
                  ["get", "seamark:signal_station_traffic:category"],
                  ["get", "seamark:signal_station_warning:category"]
