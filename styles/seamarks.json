          "#333"
        ],
        "circle-stroke-width": 1
      }
    },
    {
      "id": "distance_mark[text]",
      "type": "symbol",
      "source": "seamarks",
      "source-layer": "seamarks",
      "minzoom": 9,
      "filter": [
        "any",
        ["==", "seamark:type", "distance_mark"],
        ["==", "waterway", "milestone"]
      ],
      "layout": {
        "icon-allow-overlap": true,
        "icon-ignore-placement": true,
        "text-optional": true,
        "text-allow-overlap": false,
        "text-field": [
          "case",
          ["has", "distance"],
          ["concat", ["get", "distance"], "km"],
          [
            "concat",
            [
              "case",
              ["has", "seamark:distance_mark:distance"],
              ["get", "seamark:distance_mark:distance"],
              "?"
            ],
            [
              "match",
              ["get", "seamark:distance_mark:units"],
              "metres",
              "m",
              "feet",
              "ft",
              "kilometres",
              "km",
              "hectometres",
              "hm",
              "statute_miles",
              "mi",
              "nautical_miles",
              "nm",
              "m"
            ]
          ]
        ],
